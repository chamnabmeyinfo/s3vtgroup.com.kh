# Copy to .env and set values. Loaded automatically if the file exists (see bootstrap/app.php).

# --- Google Merchant Center (Content API for Shopping) ---
# GOOGLE_MERCHANT_ENABLED=true
# GOOGLE_MERCHANT_MERCHANT_ID=123456789
# Path to service account JSON (default: storage/private/google-merchant-credentials.json).
# Any name is fine — project-relative, e.g. storage/private/your-project-xxxxx.json
# GOOGLE_MERCHANT_CREDENTIALS_PATH=storage/private/stone-airfoil-488402-p6-5c903adb92aa.json
# GOOGLE_MERCHANT_CONTENT_LANGUAGE=en
# GOOGLE_MERCHANT_TARGET_COUNTRY=KH
# GOOGLE_MERCHANT_CURRENCY=USD
# GOOGLE_MERCHANT_DEFAULT_BRAND=Your Brand Name

# Optional tab-delimited feed (scheduled fetch fallback). Set a long random token.
# GOOGLE_MERCHANT_FEED_ENABLED=false
# GOOGLE_MERCHANT_FEED_TOKEN=replace-with-long-random-string
